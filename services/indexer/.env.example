# Soroban RPC endpoint
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# PayStream stream contract ID
STREAM_CONTRACT_ID=your-stream-contract-id

# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/paystream_indexer

# Redis Configuration (for BullMQ)
REDIS_URL=redis://localhost:6379

# How often to poll for new events (milliseconds)
POLL_INTERVAL_MS=5000

# HTTP port for the query API
PORT=3002
