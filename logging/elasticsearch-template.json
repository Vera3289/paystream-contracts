{
  "ilm_policy": {
    "name": "paystream-30d",
    "policy": {
      "phases": {
        "hot": {
          "min_age": "0ms",
          "actions": {
            "rollover": {
              "max_size": "10gb",
              "max_age": "1d"
            }
          }
        },
        "delete": {
          "min_age": "30d",
          "actions": {
            "delete": {}
          }
        }
      }
    }
  },
  "index_template": {
    "name": "paystream-logs",
    "index_patterns": ["paystream-logs-*"],
    "template": {
      "settings": {
        "number_of_shards": 1,
        "number_of_replicas": 1,
        "index.lifecycle.name": "paystream-30d",
        "index.lifecycle.rollover_alias": "paystream-logs"
      },
      "mappings": {
        "properties": {
          "@timestamp":     { "type": "date" },
          "level":          { "type": "keyword" },
          "message":        { "type": "text" },
          "service":        { "type": "keyword" },
          "correlation_id": { "type": "keyword" },
          "status":         { "type": "integer" },
          "method":         { "type": "keyword" },
          "url":            { "type": "keyword" },
          "response_time":  { "type": "float" },
          "environment":    { "type": "keyword" }
        }
      }
    }
  }
}
